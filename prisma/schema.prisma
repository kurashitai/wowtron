// WoWtron - World of Warcraft Guild Management SaaS
// Prisma Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// User Model - Platform users
model User {
  id            String      @id @default(cuid())
  email         String      @unique
  name          String?
  image         String?
  battleNetId   String?     @unique
  battleNetTag  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  // Relations
  characters    Character[]
  guilds        GuildMember[]
  signups       Signup[]
  logAnalyses   LogAnalysis[]
  playerCards   PlayerCard[]
  notifications Notification[]
  settings      UserSettings?
  
  @@map("users")
}

// User Settings
model UserSettings {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme           String   @default("dark")
  notifications   Boolean  @default(true)
  emailAlerts     Boolean  @default(false)
  discordLinked   Boolean  @default(false)
  discordId       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("user_settings")
}

// Guild Model
model Guild {
  id              String        @id @default(cuid())
  name            String
  realm           String
  faction         String        @default("Horde")
  region          String        @default("us")
  description     String?
  logo            String?
  website         String?
  discordUrl      String?
  progress        String?       // e.g., "7/9 Mythic"
  recruiting      Boolean       @default(false)
  recruitmentPost String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relations
  members         GuildMember[]
  raids           Raid[]
  characters      Character[]
  announcements   Announcement[]
  
  @@unique([name, realm])
  @@map("guilds")
}

// Guild Member (User-Guild relationship with roles)
model GuildMember {
  id          String    @id @default(cuid())
  userId      String
  guildId     String
  role        String    @default("member") // leader, officer, raider, trial, member
  joinedAt    DateTime  @default(now())
  
  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  guild       Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  
  @@unique([userId, guildId])
  @@map("guild_members")
}

// Character Model - WoW Characters
model Character {
  id              String      @id @default(cuid())
  userId          String?
  guildId         String?
  name            String
  realm           String
  region          String      @default("us")
  characterClass  String      // warrior, mage, etc.
  spec            String?     // fury, fire, etc.
  role            String?     // tank, healer, dps
  level           Int         @default(80)
  itemLevel       Int         @default(0)
  achievementPts  Int         @default(0)
  avatar          String?
  lastSynced      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  // Relations
  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  guild           Guild?      @relation(fields: [guildId], references: [id], onDelete: SetNull)
  mPlusScores     MPlusScore[]
  signups         Signup[]
  playerCard      PlayerCard?
  
  @@unique([name, realm])
  @@map("characters")
}

// M+ Score Model
model MPlusScore {
  id              String    @id @default(cuid())
  characterId     String
  season          String
  score           Float     @default(0)
  runs            Int       @default(0)
  bestRun         String?   // e.g., "Stonevault +24"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  character       Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  
  @@unique([characterId, season])
  @@map("mplus_scores")
}

// Raid Model
model Raid {
  id              String      @id @default(cuid())
  guildId         String
  name            String
  description     String?
  raidType        String      @default("progression") // progression, farm, alt
  difficulty      String      @default("heroic") // normal, heroic, mythic
  scheduledFor    DateTime
  duration        Int         @default(180) // minutes
  maxPlayers      Int         @default(30)
  status          String      @default("scheduled") // scheduled, in_progress, completed, cancelled
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  // Relations
  guild           Guild       @relation(fields: [guildId], references: [id], onDelete: Cascade)
  signups         Signup[]
  
  @@map("raids")
}

// Signup Model
model Signup {
  id              String    @id @default(cuid())
  raidId          String
  userId          String
  characterId     String
  status          String    @default("tentative") // confirmed, tentative, declined, bench
  role            String?   // tank, healer, dps
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  raid            Raid      @relation(fields: [raidId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  character       Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  
  @@unique([raidId, userId])
  @@map("signups")
}

// Log Analysis Model
model LogAnalysis {
  id              String    @id @default(cuid())
  userId          String
  logUrl          String
  reportId        String?   // Warcraft Logs report ID
  fightId         Int?
  analysisType    String    @default("raid") // raid, dungeon, pvp
  status          String    @default("pending") // pending, processing, completed, failed
  results         String?   // JSON results
  recommendations String?   // JSON recommendations
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("log_analyses")
}

// Player Card Model - Recruitment/Performance metrics
model PlayerCard {
  id                  String    @id @default(cuid())
  userId              String    @unique
  characterId         String    @unique
  headline            String?
  parseAvg            Float?    @default(0)
  deathRate           Float?    @default(0)
  avoidableDamage     Float?    @default(0)
  buffUptime          Float?    @default(0)
  mechanicErrors      Int       @default(0)
  raidsAttended       Int       @default(0)
  reliability         Float?    @default(0)
  strengths           String?   // JSON array
  improvements        String?   // JSON array
  autoMemo            String?   // AI-generated summary
  lookingForGuild     Boolean   @default(false)
  preferredRole       String?
  availability        String?   // JSON
  timezone            String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  
  // Relations
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  character           Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  
  @@map("player_cards")
}

// Announcement Model
model Announcement {
  id              String    @id @default(cuid())
  guildId         String
  title           String
  content         String
  pinned          Boolean   @default(false)
  authorId        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  guild           Guild     @relation(fields: [guildId], references: [id], onDelete: Cascade)
  
  @@map("announcements")
}

// Notification Model
model Notification {
  id              String    @id @default(cuid())
  userId          String
  type            String    // raid_reminder, signup_update, log_analysis, etc.
  title           String
  message         String
  read            Boolean   @default(false)
  link            String?
  createdAt       DateTime  @default(now())
  
  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@map("notifications")
}

model RawLogArtifact {
  key         String   @id
  artifactType String
  source      String
  cacheKey    String   @unique
  reportCode  String?
  fightId     Int?
  bossName    String?
  contentHash String
  payload     Json
  metadata    Json?
  capturedAt  DateTime
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([artifactType, capturedAt])
  @@index([reportCode, fightId])
  @@map("raw_log_artifacts")
}

model FightRecord {
  key               String            @id
  reportCode        String
  fightId           Int
  bossName          String
  zone              String
  difficulty        String
  kill              Boolean
  bossHPPercent     Float?
  durationSec       Int
  startTime         BigInt?
  endTime           BigInt?
  source            String
  capturedAt        DateTime
  composition       Json
  summary           Json
  bossContextSource String?
  dataQuality       Json?
  players           FightPlayerRecord[]
  phases            FightPhaseRecord[]
  analyzerRuns      AnalyzerRun[]

  @@unique([reportCode, fightId])
  @@index([bossName, kill])
  @@index([zone, bossName])
  @@map("fight_records")
}

model FightPlayerRecord {
  key                 String      @id
  fightKey            String
  fight               FightRecord @relation(fields: [fightKey], references: [key], onDelete: Cascade)
  actorId             Int?
  name                String
  role                String
  className           String
  spec                String
  talents             Json?
  buildSignature      String?
  buildSource         String?
  itemLevel           Int
  server              String?
  dps                 Int
  hps                 Int
  dtps                Int
  activeTime          Int
  deaths              Int
  rankPercent         Float
  reliabilityScore    Int?
  avoidableDamageTaken Int?

  @@index([fightKey, role])
  @@index([name])
  @@map("fight_player_records")
}

model FightPhaseRecord {
  key       String      @id
  fightKey  String
  fight     FightRecord @relation(fields: [fightKey], references: [key], onDelete: Cascade)
  ordinal   Int
  name      String
  startTime BigInt
  endTime   BigInt

  @@unique([fightKey, ordinal])
  @@map("fight_phase_records")
}

model AnalyzerRun {
  key             String      @id
  fightKey        String
  fight           FightRecord @relation(fields: [fightKey], references: [key], onDelete: Cascade)
  reportCode      String
  fightId         Int
  bossName        String
  source          String
  analyzerVersion String
  recordedAt      DateTime
  summaryText     String?
  topOwner        String?
  topPhase        String?
  snapshotQuality Json
  snapshot        Json
  analysis        Json
  createdAt       DateTime @default(now())

  @@index([bossName, recordedAt])
  @@index([reportCode, fightId])
  @@map("analyzer_runs")
}

model CalibrationReview {
  key           String   @id
  bossName      String
  reportCode    String
  fightId       Int
  fixtureType   String
  expected      Json
  actual        Json?
  passed        Boolean?
  failureReason String?
  tags          Json?
  reviewedAt    DateTime?
  source        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([bossName])
  @@index([reportCode, fightId])
  @@map("calibration_reviews")
}

model CoverageRollup {
  key         String   @id
  scope       String
  bossName    String?
  zone        String?
  payload     Json
  generatedAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([scope, bossName])
  @@map("coverage_rollups")
}

model RulepackGap {
  key       String   @id
  bossName  String
  phaseName String?
  status    String
  payload   Json
  updatedAt DateTime
  createdAt DateTime @default(now())

  @@index([bossName, phaseName])
  @@map("rulepack_gaps")
}

model OutputQualityReview {
  key         String   @id
  bossName    String?
  reportCode  String?
  fightId     Int?
  source      String
  payload     Json
  reviewedAt  DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([bossName, reviewedAt])
  @@map("output_quality_reviews")
}

model AnalyzerHealthSnapshot {
  key         String   @id
  scope       String
  payload     Json
  generatedAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([scope, generatedAt])
  @@map("analyzer_health_snapshots")
}

model ImprovementBacklogItem {
  key           String   @id
  category      String
  status        String
  priorityScore Int
  bossName      String?
  title         String
  rationale     String
  payload       Json
  generatedAt   DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([priorityScore, category])
  @@index([bossName, generatedAt])
  @@map("improvement_backlog_items")
}

model ReviewCadenceSnapshot {
  key         String   @id
  scope       String
  payload     Json
  generatedAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([scope, generatedAt])
  @@map("review_cadence_snapshots")
}
